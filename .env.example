# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FatSecret API Configuration (Get these at https://platform.fatsecret.com)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# Mercado Pago Configuration (Get these at https://developers.mercadopago.com)
# For local simulation (offline mock test):
#   MERCADO_PAGO_ACCESS_TOKEN= (leave empty)
#   PAYMENT_MODE=sandbox
# For sandbox testing directly on Mercado Pago's API:
#   MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (Your Test Access Token starting with TEST-)
#   PAYMENT_MODE=production (Tells server to call the API directly)
# For real production payments:
#   MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (Your Live Access Token starting with APP_USR-)
#   PAYMENT_MODE=production
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
PAYMENT_MODE=sandbox

# Evolution API Configuration (WhatsApp Integration)
EVOLUTION_API_URL=https://api.sportnutri.com
EVOLUTION_API_KEY=sportnutri_default_key
EVOLUTION_INSTANCE=sportnutri_bot

